{% extends "partials/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% set pageTitle = 'Enter a reason for this court appearance - View and manage court appearances' %}

{% block meta %}
  <meta name="autocompleteElements" content="reason"/>
{% endblock %}

{% block innerContent %}
  <div class="govuk-width-container">
    <span class="govuk-caption-l">View and manage court appearances</span>
    <form method="post">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

      {{ govukSelect({
        id: "reason",
        name: "reason",
        label: { text: "Enter a reason for this court appearance", classes: "govuk-label--l", isPageHeading: true },
        hint: { text: "Start typing the reason" },
        items: reasons | fromCodedDescription | addSelectValue('') | setSelectedValue(reason),
        errorMessage: validationErrors | findError('reason')
      }) }}

      {{ govukButton({
        classes: 'govuk-!-margin-top-6',
        text: "Save",
        preventDoubleClick: true
      }) }}
    </form>
  </div>
{% endblock %}
